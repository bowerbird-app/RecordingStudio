<%
  toast_type = case payload&.dig(:action).to_s
  when "created"
    :success
  when "deleted"
    :warning
  else
    :info
  end

  toast_message = [title, body].compact_blank.join(". ")
%>

<%= render FlatPack::Toast::Component.new(
  message: toast_message,
  type: toast_type,
  timeout: 4000
) %>
