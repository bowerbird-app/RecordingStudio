<% content_for :title, "Folders" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Folders") %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: "Folders",
  subtitle: "Folder recordings in the workspace tree.",
  class: "mb-6"
) %>

<div class="mt-8">
  <% if @folders.any? %>
    <%= render FlatPack::Table::Component.new(data: @folders) do |table| %>
    <% table.column(title: "Name", html: ->(recording) { render(FlatPack::Link::Component.new(href: folder_path(recording))) { recording.name } }) %>
    <% table.column(title: "Parent", html: ->(recording) { recording.parent_recording&.name || "—" }) %>
    <% table.column(title: "Root", html: ->(recording) { recording.root_recording&.name || "—" }) %>
    <% end %>
  <% else %>
    <%= render FlatPack::Alert::Component.new(description: "No folders found.", style: :info) %>
  <% end %>
</div>
