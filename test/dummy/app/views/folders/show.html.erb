<% content_for :title, @recording.title %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Folders", href: folders_path) %>
  <% breadcrumb.item(text: @recording.title) %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: @recording.title,
  subtitle: "Folder recording details and children.",
  class: "mb-6"
) do |page_title| %>
  <% page_title.actions do %>
    <%= render FlatPack::Button::Component.new(text: "Back to Folders", style: :secondary, url: folders_path) %>
  <% end %>
<% end %>

<%= render FlatPack::Card::Component.new(class: "mt-8", padding: :none) do |card| %>
  <% card.body do %>
    <% if @children.any? %>
      <%= render FlatPack::Table::Component.new(data: @children) do |table| %>
      <% table.column(title: "Recordable", html: ->(recording) {
        case recording.recordable_type
        when "RecordingStudioFolder"
          render(FlatPack::Link::Component.new(href: folder_path(recording))) { recording.name }
        when "RecordingStudioPage"
          render(FlatPack::Link::Component.new(href: recording_path(recording))) { recording.name }
        else
          render(FlatPack::Link::Component.new(href: recording_path(recording))) { recording.name }
        end
      }) %>
        <% table.column(title: "Type", html: ->(recording) { recording.type_label }) %>
      <% end %>
    <% else %>
      <%= render FlatPack::Alert::Component.new(description: "No child recordings.", style: :info) %>
    <% end %>
  <% end %>
<% end %>
