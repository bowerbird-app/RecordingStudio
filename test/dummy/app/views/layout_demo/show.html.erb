<% recording_studio_page_nav(
  title: "Default Layout Demo",
  page_nav_anchor_url: workspaces_path,
  page_nav_anchor_label: "Close demo"
) %>

<% default_layout_head do %>
  <meta name="recording-studio-demo" content="default-layout">
<% end %>

<% recording_studio_seo_description("RecordingStudio layout demo page with PageNav, SEO, and OpenGraph support") %>
<% recording_studio_seo_image("https://example.com/og-image.png") %>

<% recording_studio_page_nav_right do %>
  <%= render FlatPack::Button::Component.new(text: "Create workspace", style: :secondary, url: new_workspace_path) %>
<% end %>

<div class="space-y-3 p-4">
  <h1 class="text-lg font-semibold">Default Layout Demo</h1>
  <p>
    This page demonstrates the shared RecordingStudio default layout with PageNav above direct page content.
  </p>
</div>
