<% content_for :title, "Recordings" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Recordings") %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: "Recordings",
  subtitle: "A complete history of activity across your workspace.",
  class: "mb-6"
) %>

<div class="mt-8">
  <% if @recordings.any? %>
    <%= render FlatPack::Table::Component.new(data: @recordings) do |table| %>
    <% table.column(
      title: "Recordable",
      html: ->(recording) { render(FlatPack::Link::Component.new(href: recording_path(recording))) { recording.name } }
    ) %>

    <% table.column(title: "Type", html: ->(recording) { recording.type_label }) %>

    <% table.column(
      title: "Root",
      html: ->(recording) { recording.root_recording&.name || "—" }
    ) %>

    <% table.column(
      title: "Last updated by",
      html: ->(recording) {
        last_event = recording.events.recent.first
        actor_label(last_event&.actor)
      }
    ) %>

    <% table.column(title: "Updated", html: ->(recording) { "#{time_ago_in_words(recording.updated_at)} ago" }) %>
    <% table.column(
      title: "Actions",
      html: ->(recording) { render(FlatPack::Link::Component.new(href: recording_path(recording))) { "View" } }
    ) %>
    <% end %>
  <% else %>
    <%= render FlatPack::Alert::Component.new(description: "No recordings yet.", style: :info) %>
  <% end %>
</div>
