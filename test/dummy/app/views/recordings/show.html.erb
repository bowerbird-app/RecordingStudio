<% content_for :title, "Recording" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Recordings", href: recordings_path) %>
  <% breadcrumb.item(text: @recording.name) %>
<% end %>

<% summary = @recording.summary %>

<div class="space-y-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: @recording.title,
    subtitle: summary.presence,
    class: "mb-0",
    variant: :h1
  ) %>

  <% child_recordings = @recording.child_recordings.recent %>
  <%= render FlatPack::Card::Component.new(padding: :none) do |card| %>
    <% card.header do %>
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Child recordings",
        class: "my-0"
      ) %>
    <% end %>
    <% card.body do %>
      <% if child_recordings.any? %>
        <%= render FlatPack::Table::Component.new(data: child_recordings) do |table| %>
          <% table.column(title: "Recordable", html: ->(child) { render(FlatPack::Link::Component.new(href: recording_path(child))) { child.name } }) %>
          <% table.column(title: "Recording ID", html: ->(child) { child.id }) %>
          <% table.column(title: "Parent ID", html: ->(child) { child.parent_recording_id }) %>
          <% table.column(title: "Details", html: ->(child) {
            if child.recordable.respond_to?(:body) && child.recordable.body.present?
              child.recordable.body
            elsif child.recordable.respond_to?(:summary) && child.recordable.summary.present?
              child.recordable.summary
            else
              "-"
            end
          }) %>
        <% end %>
      <% else %>
        <%= render FlatPack::Alert::Component.new(message: "No child recordings yet.", style: :info) %>
      <% end %>
    <% end %>
  <% end %>

  <% snapshot_rows = [
    { label: "Recordable Type", value: @recording.type_label },
    { label: "Recordable ID", value: @recording.recordable.id },
    { label: "Last updated", value: "#{time_ago_in_words(@recording.updated_at)} ago" },
    { label: "Root Recording ID", value: @recording.root_recording_id },
    { label: "Root Recordable", value: @recording.root_recording&.name || "—" }
  ] %>
  <%= render FlatPack::Card::Component.new(padding: :none) do |card| %>
    <% card.header do %>
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Recording Snapshot",
        class: "my-0"
      ) %>
    <% end %>
    <% card.body do %>
      <%= render FlatPack::Table::Component.new(data: snapshot_rows) do |table| %>
        <% table.column(title: "Field", html: ->(row) { row[:label] }) %>
        <% table.column(title: "Value", html: ->(row) { row[:value] }) %>
      <% end %>
    <% end %>
  <% end %>

  <%= render FlatPack::Grid::Component.new(cols: 2, gap: :lg, align: :start) do %>
    <%= render FlatPack::Card::Component.new(padding: :none) do |card| %>
      <% card.header do %>
        <%= render FlatPack::SectionTitle::Component.new(
          title: "History",
          subtitle: "Timeline entries for this recording and its related recordables.",
          class: "my-0"
        ) %>
      <% end %>
      <% card.body do %>
        <% current_recordable_id = @recording.recordable.id %>
        <% current_event_id = @events.find { |entry| entry.recordable&.id == current_recordable_id }&.id %>
        <% if @events.any? %>
          <% timeline_items = @events.each_with_index.map do |event, index| %>
            <% event_rows = [
              { label: "Actor", value: actor_with_impersonator_label(event.actor, event.impersonator) },
              { label: "Recordable", value: recordable_name(event.recordable) },
              { label: "Previous", value: recordable_name(event.previous_recordable) }
            ] %>
            <% target_recordable = if event.recordable && event.recordable.id != @recording.recordable.id
              event.recordable
            elsif event.previous_recordable && event.previous_recordable.id != @recording.recordable.id
              event.previous_recordable
            end %>
            <% variant = case event.action.to_s
            when "created"
              :success
            when "deleted"
              :warning
            else
              :default
            end %>
            <% render(FlatPack::Timeline::Item.new(
              title: event.action.to_s.titleize,
              timestamp: "#{time_ago_in_words(event.occurred_at)} ago",
              variant: variant,
              last: index == @events.length - 1
            )) do %>
              <%= render FlatPack::Badge::Component.new(text: "Current", style: :success, size: :sm, class: "mb-3") if current_event_id && event.id == current_event_id %>
              <%= render FlatPack::List::Component.new(spacing: :dense, divider: true, class: "mb-3") do %>
                <%= safe_join(event_rows.map { |row| render(FlatPack::List::Item.new(trailing: row[:value])) { row[:label] } }) %>
              <% end %>
              <% if event.metadata.present? %>
                <%= render FlatPack::CodeBlock::Component.new(
                  code: JSON.pretty_generate(event.metadata),
                  language: :json,
                  title: "Metadata",
                  separated: false,
                  class: "mt-3"
                ) %>
              <% end %>
              <% if target_recordable && (!current_event_id || event.id != current_event_id) %>
                <%= render FlatPack::Button::Component.new(
                  text: "Revert",
                  url: revert_recording_path(@recording, recordable_id: target_recordable.id),
                  method: :post,
                  style: :secondary,
                  size: :sm,
                  class: "mt-3"
                ) %>
              <% end %>
            <% end %>
          <% end %>

          <%= render FlatPack::Timeline::Component.new do %>
            <%= safe_join(timeline_items) %>
          <% end %>
        <% else %>
          <%= render FlatPack::Alert::Component.new(message: "No history yet.", style: :info) %>
        <% end %>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(padding: :none) do |card| %>
      <% card.header do %>
        <%= render FlatPack::SectionTitle::Component.new(
          title: "Recordables",
          subtitle: "All snapshots referenced by this recording, including previous versions.",
          class: "my-0"
        ) %>
      <% end %>
      <% card.body do %>
        <% if @recordables.any? %>
          <%= render FlatPack::Table::Component.new(data: @recordables) do |table| %>
            <% table.column(
              title: "Recordable",
              html: ->(recordable) {
                safe_join([
                  recordable_name(recordable),
                  (render(FlatPack::Badge::Component.new(text: "Current", style: :success, size: :sm)) if recordable.id == @recording.recordable.id)
                ].compact, " ".html_safe)
              }
            ) %>
            <% table.column(
              title: "Summary",
              html: ->(recordable) {
                if recordable.respond_to?(:summary) && recordable.summary.present?
                  recordable.summary
                else
                  "No summary available."
                end
              }
            ) %>
            <% table.column(title: "Recordings", html: ->(recordable) { recordable.respond_to?(:recordings_count) ? recordable.recordings_count : 0 }) %>
            <% table.column(title: "Events", html: ->(recordable) { recordable.respond_to?(:events_count) ? recordable.events_count : 0 }) %>
            <% table.column(title: "ID", html: ->(recordable) { recordable.id }) %>
          <% end %>
        <% else %>
          <%= render FlatPack::Alert::Component.new(message: "No recordables yet.", style: :info) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
