<%= form_with model: workspace, class: "space-y-6" do |_form| %>
  <%= render FlatPack::TextInput::Component.new(
    name: "workspace[name]",
    label: "Name",
    value: workspace.name
  ) %>

  <%= render FlatPack::Grid::Component.new(cols: 2, gap: :md, align: :center) do %>
    <%= render FlatPack::Button::Component.new(text: "Create Workspace", type: "submit", style: :primary) %>
    <%= render FlatPack::Button::Component.new(text: "Cancel", url: workspaces_path, style: :ghost) %>
  <% end %>
<% end %>
