<%= form_with model: workspace, class: "space-y-6" do |_form| %>
  <%= render FlatPack::TextInput::Component.new(
    name: "workspace[name]",
    label: "Name",
    value: workspace.name
  ) %>

  <div class="flex items-center gap-3">
    <%= render FlatPack::Button::Component.new(text: "Create Workspace", type: "submit", class: "rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white") %>
    <%= render FlatPack::Button::Component.new(text: "Cancel", url: workspaces_path, class: "text-sm font-medium text-slate-500") %>
  </div>
<% end %>
