<% recording_studio_page_nav(
  title: "Workspaces",
  page_nav_anchor_url: root_path,
  page_nav_anchor_icon: "home",
  page_nav_anchor_label: "Home"
) %>

<% recording_studio_page_nav_right do %>
  <%= render FlatPack::Button::Component.new(
    icon: "plus",
    icon_only: true,
    style: :secondary,
    size: :md,
    url: new_workspace_path,
    aria: { label: "Add workspace" }
  ) %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: "Workspaces",
  subtitle: "Choose a workspace explicitly before browsing or creating workspace-rooted pages."
) %>

<div class="mt-8">
  <% if @workspaces&.any? %>
    <%= render FlatPack::Table::Component.new(data: @workspaces) do |table| %>
    <% table.column(title: "Name", html: ->(workspace) { render(FlatPack::Link::Component.new(href: workspace_path(workspace))) { workspace.name } }) %>
    <% table.column(title: "Created", html: ->(workspace) { "#{time_ago_in_words(workspace.created_at)} ago" }) %>

    <% end %>
  <% else %>
    <%= render FlatPack::Alert::Component.new(description: "No workspaces yet. Create one to start recording.", style: :info) %>
  <% end %>
</div>
