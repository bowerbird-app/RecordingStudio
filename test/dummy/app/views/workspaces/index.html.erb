<% content_for :title, "Workspaces" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Workspaces") %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: "Workspaces",
  subtitle: "Choose a workspace explicitly before browsing or creating workspace-rooted pages."
) do |page_title| %>
  <% page_title.actions do %>
    <%= render FlatPack::Button::Component.new(text: "New Workspace", style: :primary, url: new_workspace_path) %>
  <% end %>
<% end %>

<div class="mt-8">
  <% if @workspaces&.any? %>
    <%= render FlatPack::Table::Component.new(data: @workspaces) do |table| %>
    <% table.column(title: "Name", html: ->(workspace) { render(FlatPack::Link::Component.new(href: workspace_path(workspace))) { workspace.name } }) %>
    <% table.column(title: "Created", html: ->(workspace) { "#{time_ago_in_words(workspace.created_at)} ago" }) %>

    <% end %>
  <% else %>
    <%= render FlatPack::Alert::Component.new(message: "No workspaces yet. Create one to start recording.", style: :info) %>
  <% end %>
</div>
