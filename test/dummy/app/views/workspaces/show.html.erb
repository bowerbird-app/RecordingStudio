<% content_for :title, @workspace.name %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Workspaces", href: workspaces_path) %>
  <% breadcrumb.item(text: @workspace.name) %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: @workspace.name,
  subtitle: "A workspace root recording with explicit page routes and its full recording tree."
) do |page_title| %>
  <% page_title.actions do %>
    <%= render FlatPack::Button::Component.new(text: "Back to Workspaces", style: :secondary, url: workspaces_path) %>
    <%= render FlatPack::Button::Component.new(text: "Browse Pages", style: :secondary, url: workspace_pages_path(@workspace)) %>
    <%= render FlatPack::Button::Component.new(text: "New Page", style: :primary, url: new_workspace_page_path(@workspace)) %>
    <%= render FlatPack::Button::Component.new(text: "Browse Recordings", style: :secondary, url: recordings_path) %>
  <% end %>
<% end %>

<%= render FlatPack::Card::Component.new(class: "mb-6", padding: :none) do |card| %>
  <% card.header(divider: false) do %>
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Recording hierarchy",
      subtitle: "Child recordings nested under their parents.",
      class: "my-0"
    ) %>
  <% end %>

  <% card.body do %>
    <% if @recordings.any? %>
      <%= recordings_hierarchy_list(@recordings_by_parent, parent_id: @root_recording.id) %>
    <% else %>
      <%= render FlatPack::Alert::Component.new(message: "No recordings yet.", style: :info) %>
    <% end %>
  <% end %>
<% end %>
