<% recording_studio_page_nav(
  title: "New Workspace",
  page_nav_anchor_url: workspaces_path,
  page_nav_anchor_icon: "chevron-left",
  page_nav_anchor_label: "Workspaces"
) %>

<%= render FlatPack::Grid::Component.new(cols: 1, gap: :lg, class: "max-w-2xl") do %>
  <%= render FlatPack::PageTitle::Component.new(
    title: "New Workspace",
    subtitle: "Create a container for recordings.",
    class: "mb-0"
  ) %>

  <%= render FlatPack::Card::Component.new(padding: :none) do |card| %>
    <% card.body do %>
      <%= render "form", workspace: @workspace %>
    <% end %>
  <% end %>
<% end %>
