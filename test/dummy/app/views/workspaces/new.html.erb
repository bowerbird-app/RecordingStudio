<% content_for :title, "New Workspace" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Workspaces", href: workspaces_path) %>
  <% breadcrumb.item(text: "New") %>
<% end %>

<%= render FlatPack::Grid::Component.new(cols: 1, gap: :lg, class: "max-w-2xl") do %>
  <%= render FlatPack::PageTitle::Component.new(
    title: "New Workspace",
    subtitle: "Create a container for recordings.",
    class: "mb-0"
  ) %>

  <%= render FlatPack::Card::Component.new(padding: :none) do |card| %>
    <% card.body do %>
      <%= render "form", workspace: @workspace %>
    <% end %>
  <% end %>
<% end %>
