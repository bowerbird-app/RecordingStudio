<% content_for :title, "Methods" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Methods") %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: "Methods",
  subtitle: "Reference examples for the RecordingStudio public API and the addon-style capability surface used in this demo.",
  class: "mb-6"
) %>

<div class="space-y-6">
  <% @method_catalog.each do |entry| %>
    <section class="space-y-3">
      <%= render FlatPack::SectionTitle::Component.new(
        title: entry[:title],
        subtitle: entry[:subtitle],
        class: "my-0"
      ) %>
      <%= render FlatPack::CodeBlock::Component.new(
        code: entry[:code],
        language: :ruby,
        title: entry[:subtitle],
        separated: false
      ) %>
    </section>
  <% end %>
</div>