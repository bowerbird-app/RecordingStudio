<%= render FlatPack::PageTitle::Component.new(
  title: "Recording Studio Demo",
  subtitle: "Explore explicit workspace-root recordings, revisions, folders, capability hooks, and events in a demo app with no hidden current workspace."
) do |page_title| %>
  <% page_title.actions do %>
    <%= render FlatPack::Button::Component.new(text: "Workspaces", style: :secondary, url: workspaces_path) %>
    <%= render FlatPack::Button::Component.new(text: "Folders", style: :secondary, url: folders_path) %>
    <%= render FlatPack::Button::Component.new(text: "Events", style: :secondary, url: events_path) %>
    <%= render FlatPack::Button::Component.new(text: "Recordings", style: :secondary, url: recordings_path) %>
  <% end %>
<% end %>
