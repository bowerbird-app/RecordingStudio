<% content_for :title, "Events" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Events") %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: "Events",
  subtitle: "Recent changes across recordings and recordables.",
  class: "mb-6"
) %>

<div class="mt-8">
  <% if @events.any? %>
    <%= render FlatPack::Table::Component.new(data: @events) do |table| %>
    <% table.column(
      title: "Action",
      html: ->(event) {
        action = event.action.to_s
        style = case action
                when "created"
                  :success
                when "updated"
                  :info
                when "deleted"
                  :warning
                else
                  :default
                end

        render FlatPack::Badge::Component.new(text: action, style: style, size: :sm)
      }
    ) %>
    <% table.column(
      title: "Occurred",
      html: ->(event) { tag.span("#{time_ago_in_words(event.occurred_at)} ago", title: l(event.occurred_at, format: :long)) }
    ) %>
    <% table.column(
      title: "Actor",
      html: ->(event) { actor_with_impersonator_label(event.actor, event.impersonator) }
    ) %>
    <% table.column(
      title: "Impersonator",
      html: ->(event) { event.impersonator ? actor_label(event.impersonator) : "—" }
    ) %>
    <% table.column(
      title: "Recordable",
      html: ->(event) {
        safe_join([
          recordable_name(event.recordable),
          ("Previous: #{recordable_name(event.previous_recordable)}" if event.previous_recordable)
        ].compact.map { |entry| tag.div(entry, class: entry.start_with?("Previous:") ? "text-xs text-(--surface-muted-content-color)" : nil) })
      }
    ) %>
    <% table.column(
      title: "Recording",
      html: ->(event) {
        if event.recording
          render(FlatPack::Link::Component.new(href: recording_path(event.recording))) { "Recording ##{event.recording.id}" }
        else
          "—"
        end
      }
    ) %>
      <% table.column(
        title: "Event ID",
        html: ->(event) { event.id }
      ) %>
    <% end %>
  <% else %>
    <%= render FlatPack::Alert::Component.new(description: "No events yet.", style: :info) %>
  <% end %>
</div>
