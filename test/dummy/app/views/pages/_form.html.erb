<%= form_with url: form_url, method: form_method, scope: :page, class: "space-y-6" do |_form| %>
  <%= render FlatPack::TextInput::Component.new(
    name: "page[title]",
    label: "Title",
    value: recordable.title
  ) %>

  <%= render FlatPack::TextArea::Component.new(
    name: "page[summary]",
    label: "Summary",
    value: recordable.summary,
    rows: 5
  ) %>

  <%= render FlatPack::Grid::Component.new(cols: 2, gap: :md, align: :center) do %>
    <%= render FlatPack::Button::Component.new(text: submit_label, type: "submit", style: :primary) %>
    <%= render FlatPack::Button::Component.new(text: "Cancel", url: cancel_url, style: :ghost) %>
  <% end %>
<% end %>
