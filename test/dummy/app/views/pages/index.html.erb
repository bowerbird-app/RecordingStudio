<% content_for :title, "Pages" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Workspaces", href: workspaces_path) %>
  <% breadcrumb.item(text: @workspace.name, href: workspace_path(@workspace)) %>
  <% breadcrumb.item(text: "Pages") %>
<% end %>

<%= render FlatPack::PageHeader::Component.new(
  title: "#{@workspace.name} Pages",
  subtitle: "Workspace-rooted page recordings for this demo workspace.",
  class: "mb-6"
) do %>
  <div class="flex flex-wrap items-center gap-2">
    <%= render FlatPack::Button::Component.new(text: "Back to Workspace", style: :secondary, url: workspace_path(@workspace)) %>
    <%= render FlatPack::Button::Component.new(text: "New Page", style: :primary, url: new_workspace_page_path(@workspace)) %>
  </div>
<% end %>

<%= render FlatPack::Card::Component.new(class: "mt-8 overflow-hidden rounded-lg border border-slate-200 bg-white") do |card| %>
  <% card.body do %>
    <% if @recordings.any? %>
      <%= render FlatPack::Table::Component.new(data: @recordings) do |table| %>
      <% table.column(
        title: "Title",
        html: ->(recording) { link_to(recording.recordable.title, recording_path(recording), class: "hover:underline") }
      ) %>

      <% table.column(
        title: "Children",
        html: ->(recording) { recording.child_recordings.count }
      ) %>

      <% table.column(
        title: "Last updated by",
        html: ->(recording) {
          last_event = recording.events.recent.first
          actor_label(last_event&.actor)
        }
      ) %>

      <% table.column(title: "Updated", html: ->(recording) { "#{time_ago_in_words(recording.updated_at)} ago" }) %>

        <% table.with_action(text: "View", url: ->(recording) { recording_path(recording) }) %>
        <% table.with_action(text: "Edit", url: ->(recording) { edit_workspace_page_path(@workspace, recording) }) %>
      <% end %>
    <% else %>
      <div class="px-6 py-10 text-center text-sm text-slate-500">
        No pages yet. Create one to see recordings in action.
      </div>
    <% end %>
  <% end %>
<% end %>
