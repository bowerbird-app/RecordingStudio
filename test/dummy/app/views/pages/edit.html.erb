<% content_for :title, "Edit Page" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Workspaces", href: workspaces_path) %>
  <% breadcrumb.item(text: @workspace.name, href: workspace_path(@workspace)) %>
  <% breadcrumb.item(text: "Pages", href: workspace_pages_path(@workspace)) %>
  <% breadcrumb.item(text: @recording.name, href: workspace_page_path(@workspace, @recording)) %>
  <% breadcrumb.item(text: "Edit") %>
<% end %>

<div class="max-w-2xl space-y-6">
  <%= render FlatPack::PageHeader::Component.new(
    title: "Edit Page",
    subtitle: "Create a new snapshot for a page inside #{@workspace.name}.",
    class: "mb-0"
  ) %>

  <%= render FlatPack::Card::Component.new(class: "rounded-lg border border-slate-200 bg-white p-6") do |card| %>
    <% card.body do %>
      <%= render "form", recordable: @recordable, form_url: workspace_page_path(@workspace, @recording), form_method: :patch, submit_label: "Save Revision", cancel_url: workspace_page_path(@workspace, @recording) %>
    <% end %>
  <% end %>
</div>
