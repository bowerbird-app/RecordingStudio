<%= render FlatPack::Sidebar::Component.new do |sidebar| %>
  <% sidebar.header do %>
    <%= render FlatPack::Sidebar::Header::Component.new(
      brand_abbr: "RS",
      title: "RecordingStudio"
    ) %>
  <% end %>

  <% sidebar.items do %>
    <%= render FlatPack::Sidebar::Item::Component.new(label: "Home", href: root_path, icon: "home", active: current_page?(root_path)) %>
    <%= render FlatPack::Sidebar::Item::Component.new(label: "Tree", href: tree_path, icon: "folder", active: current_page?(tree_path)) %>
    <%= render FlatPack::Sidebar::Group::Component.new(
      label: "Methods",
      icon: "document",
      default_open: current_page?(methods_path) ||
        current_page?(identity_methods_path) ||
        current_page?(crud_methods_path) ||
        current_page?(event_methods_path) ||
        current_page?(root_methods_path) ||
        current_page?(query_methods_path) ||
        current_page?(tree_methods_path) ||
        current_page?(capabilities_path)
    ) do |group| %>
      <% group.items do %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Config", href: methods_path, icon: "squares-2x2", active: current_page?(methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Identity", href: identity_methods_path, icon: "identification", active: current_page?(identity_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "CRUD", href: crud_methods_path, icon: "wrench-screwdriver", active: current_page?(crud_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Events", href: event_methods_path, icon: "bolt", active: current_page?(event_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Root", href: root_methods_path, icon: "home-modern", active: current_page?(root_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Queries", href: query_methods_path, icon: "magnifying-glass", active: current_page?(query_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Tree", href: tree_methods_path, icon: "folder", active: current_page?(tree_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Capabilties", href: capabilities_path, icon: "shield-check", active: current_page?(capabilities_path)) %>
      <% end %>
    <% end %>
  <% end %>

  <% sidebar.footer do %>
    <%= render FlatPack::Sidebar::Footer::Component.new do %>
      <%= render FlatPack::Button::Component.new(url: destroy_user_session_path, method: :delete, style: :ghost, text: "Log out", icon: "arrow-left-on-rectangle") %>
    <% end %>
  <% end %>
<% end %>