<%= render FlatPack::Sidebar::Component.new do |sidebar| %>
  <% sidebar.header do %>
    <%= render FlatPack::Sidebar::Header::Component.new(
      brand_abbr: "RS",
      title: "RecordingStudio"
    ) do %>
      <div class="flex items-center gap-3" data-flat-pack--sidebar-layout-target="headerRow">
        <div class="flex items-center gap-3" data-flat-pack--sidebar-layout-target="headerBrand">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center font-bold bg-[var(--sidebar-header-badge-background-color)] text-[var(--sidebar-header-badge-text-color)]">
            RS
          </div>
          <div class="flex items-center h-8" data-flat-pack--sidebar-layout-target="headerLabel">
            <div class="font-semibold text-sm text-[var(--sidebar-header-text-color)]">RecordingStudio</div>
            <span class="ml-2 inline-flex items-center rounded-md border px-2 py-0.5 text-[10px] leading-none font-medium bg-[var(--badge-default-background-color)] text-[var(--badge-default-text-color)] border-[var(--badge-default-border-color)]">
              v<%= RecordingStudio::VERSION %>
            </span>
          </div>
        </div>
        <button type="button"
                class="hidden items-center justify-center p-2 rounded-lg text-[var(--sidebar-header-icon-color)] hover:bg-[var(--sidebar-header-icon-hover-background-color)] hover:text-[var(--sidebar-header-icon-hover-color)] transition-colors"
                data-flat-pack--sidebar-layout-target="collapsedToggle"
                data-action="click->flat-pack--sidebar-layout#toggleDesktop"
                aria-label="Open sidebar"
                aria-expanded="false">
          <%= render FlatPack::Shared::IconComponent.new(name: :menu, size: :md) %>
        </button>
        <button type="button"
                class="hidden ml-auto p-2 rounded-lg text-[var(--sidebar-header-icon-color)] hover:bg-[var(--sidebar-header-icon-hover-background-color)] hover:text-[var(--sidebar-header-icon-hover-color)] transition-colors"
                data-flat-pack--sidebar-layout-target="desktopToggle"
                data-action="click->flat-pack--sidebar-layout#toggleDesktop click->flat-pack--sidebar-layout#toggleMobile"
                aria-label="Collapse sidebar"
                aria-expanded="true">
          <span class="flex-shrink-0 transition-transform duration-300" data-flat-pack--sidebar-layout-target="chevron">
            <%= render FlatPack::Shared::IconComponent.new(name: :chevron_left, size: :md) %>
          </span>
        </button>
      </div>
    <% end %>
  <% end %>

  <% sidebar.items do %>
    <%= render FlatPack::Sidebar::Item::Component.new(label: "Home", href: root_path, icon: "home", active: current_page?(root_path)) %>
    <%= render FlatPack::Sidebar::Item::Component.new(label: "Tree", href: tree_path, icon: "folder", active: current_page?(tree_path)) %>
    <%= render FlatPack::Sidebar::Group::Component.new(
      label: "Methods",
      icon: "document",
      default_open: current_page?(methods_path) ||
        current_page?(recordable_methods_path) ||
        current_page?(identity_methods_path) ||
        current_page?(crud_methods_path) ||
        current_page?(event_methods_path) ||
        current_page?(root_methods_path) ||
        current_page?(query_methods_path) ||
        current_page?(tree_methods_path) ||
        current_page?(depreciated_methods_path) ||
        current_page?(capabilities_path) ||
        current_page?(orphans_path)
    ) do |group| %>
      <% group.items do %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Config", href: methods_path, icon: "squares-2x2", active: current_page?(methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Recordables", href: recordable_methods_path, icon: "rectangle-stack", active: current_page?(recordable_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Identity", href: identity_methods_path, icon: "identification", active: current_page?(identity_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "CRUD", href: crud_methods_path, icon: "wrench-screwdriver", active: current_page?(crud_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Events", href: event_methods_path, icon: "bolt", active: current_page?(event_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Root", href: root_methods_path, icon: "home-modern", active: current_page?(root_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Queries", href: query_methods_path, icon: "magnifying-glass", active: current_page?(query_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Tree", href: tree_methods_path, icon: "folder", active: current_page?(tree_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Depreciated", href: depreciated_methods_path, icon: "exclamation-triangle", active: current_page?(depreciated_methods_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Capabilities", href: capabilities_path, icon: "shield-check", active: current_page?(capabilities_path)) %>
        <%= render FlatPack::Sidebar::Item::Component.new(label: "Orphans", href: orphans_path, icon: "shield-check", active: current_page?(orphans_path)) %>
      <% end %>
    <% end %>
  <% end %>

  <% sidebar.footer do %>
    <%= render FlatPack::Sidebar::Footer::Component.new do %>
      <% logout_button_classes = [
        "w-full inline-flex items-center justify-center gap-2",
        "rounded-[var(--button-border-radius)] font-medium cursor-pointer transition-colors duration-base",
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--button-focus-ring-color)]",
        "focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--button-focus-ring-offset-color)]",
        "disabled:pointer-events-none disabled:opacity-[var(--button-disabled-opacity)]",
        FlatPack::Button::Component::SIZES.fetch(:md),
        FlatPack::Button::Component::SCHEMES.fetch(:ghost)
      ].join(" ") %>
      <%= button_to destroy_user_session_path,
            method: :delete,
            form: { class: "w-full", data: { turbo: false } },
            class: logout_button_classes do %>
        <%= render FlatPack::Shared::IconComponent.new(name: "arrow-left-on-rectangle", size: :md) %>
        <span>Log out</span>
      <% end %>
    <% end %>
  <% end %>
<% end %>