<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "RecordingStudio Sandbox" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Dummy">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "flat_pack/rich_text", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags if respond_to?(:javascript_importmap_tags) %>

  </head>

  <body data-theme="rounded" class="bg-(--surface-page-background-color) text-(--surface-content-color)">
    <%= turbo_stream_from "recording_studio_toasts" if respond_to?(:turbo_stream_from) %>
    <%= render FlatPack::SidebarLayout::Component.new do |layout| %>
      <% if user_signed_in? %>
        <% layout.sidebar do %>
          <%= render "layouts/flat_pack/sidebar" %>
        <% end %>
      <% end %>
      <% layout.top_nav do %>
        <%= render "layouts/flat_pack/top_nav" %>
      <% end %>
      <% layout.main do %>
        <main class="mx-auto w-full max-w-6xl p-6">
          <% if flash[:notice].present? %>
            <%= render FlatPack::Alert::Component.new(description: flash[:notice], style: :success, class: "mb-6") %>
          <% end %>
          <% if flash[:alert].present? %>
            <%= render FlatPack::Alert::Component.new(description: flash[:alert], style: :danger, class: "mb-6") %>
          <% end %>
          <%= yield %>
        </main>
      <% end %>
    <% end %>
    <%= render FlatPack::Toasts::Region::Component.new(id: "toast-container", data: { turbo_permanent: true }) %>
  </body>
</html>
