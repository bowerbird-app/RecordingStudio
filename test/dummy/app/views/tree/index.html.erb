<% content_for :title, "Tree" %>

<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Home", href: root_path) %>
  <% breadcrumb.item(text: "Tree") %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: "Tree",
  subtitle: "Browse the dummy app recording hierarchy as a Flatpack tree of workspaces, folders, and pages.",
  class: "mb-6"
) %>

<%= render FlatPack::Card::Component.new(class: "max-w-3xl", padding: :none) do |card| %>
  <% card.body do %>
    <% if @recordings.any? %>
      <%= render FlatPack::Tree::Component.new(compact: true, class: "w-full") do |tree| %>
        <% render_recording_tree_nodes(tree, @recordings_by_parent) %>
      <% end %>
    <% else %>
      <%= render FlatPack::Alert::Component.new(description: "No recordings yet.", style: :info) %>
    <% end %>
  <% end %>
<% end %>