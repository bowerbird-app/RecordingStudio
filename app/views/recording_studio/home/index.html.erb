<div class="mx-auto max-w-3xl space-y-6 py-12">
  <%= render FlatPack::PageHeader::Component.new(
    title: "Recordings, Recordables, Events",
    subtitle: "This engine provides a root recording API for creating immutable recordable snapshots and an append-only event timeline. Mount it inside your host app and customize via the RecordingStudio initializer.",
    class: "mb-0",
    title_tag: :h1
  ) %>

  <%= render FlatPack::Card::Component.new(style: :default, padding: :none) do |card| %>
    <% card.body do %>
      <p class="font-semibold text-slate-900">Next steps</p>
      <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-600">
        <li>Run <code class="rounded bg-slate-100 px-2 py-1 text-xs">rails g recording_studio:migrations</code> to install tables.</li>
        <li>Register recordable types in <code class="rounded bg-slate-100 px-2 py-1 text-xs">config/initializers/recording_studio.rb</code>.</li>
        <li>Create a root Recording per top-level recordable and call recording APIs from that root.</li>
      </ul>
    <% end %>
  <% end %>
</div>
