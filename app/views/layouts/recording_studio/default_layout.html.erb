<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title).presence || "RecordingStudio" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= javascript_importmap_tags if respond_to?(:javascript_importmap_tags) %>
  </head>

  <body class="bg-(--surface-page-background-color) text-(--surface-content-color)">
    <main class="mx-auto w-full max-w-4xl p-6">
      <% if flash[:notice].present? %>
        <%= render FlatPack::Alert::Component.new(description: flash[:notice], style: :success, class: "mb-4") %>
      <% end %>
      <% if flash[:alert].present? %>
        <%= render FlatPack::Alert::Component.new(description: flash[:alert], style: :danger, class: "mb-4") %>
      <% end %>

      <% page_nav_options = {
        back_icon: content_for(:page_nav_back_icon).presence || "chevron-left",
        back_label: content_for(:page_nav_back_label).presence || "Go back",
        back_style: (content_for(:page_nav_back_style).presence || "secondary").to_sym,
        back_size: (content_for(:page_nav_back_size).presence || "md").to_sym,
        anchor_icon: content_for(:page_nav_anchor_icon).presence || "x-mark",
        anchor_label: content_for(:page_nav_anchor_label).presence || "Close"
      } %>
      <% anchor_url = content_for(:page_nav_anchor_url).presence %>
      <% page_nav_options[:anchor_url] = anchor_url if anchor_url.present? %>

      <div class="mb-4">
        <% if content_for?(:page_nav_right) %>
          <%= render FlatPack::PageNav::Component.new(**page_nav_options) do |page_nav| %>
            <% page_nav.right_slot do %>
              <%= yield :page_nav_right %>
            <% end %>
          <% end %>
        <% else %>
          <%= render FlatPack::PageNav::Component.new(**page_nav_options) %>
        <% end %>
      </div>

      <%= render FlatPack::Card::Component.new(padding: :none) do |card| %>
        <% card.body do %>
          <%= yield %>
        <% end %>
      <% end %>
    </main>
  </body>
</html>
